# Flask / Database configuration
FLASK_SECRET_KEY=change-this-to-a-long-random-secret
DATABASE_URL=sqlite:///placement_portal.db

# Session cookie security
# Set to True only when running behind HTTPS
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax

# Optional auto-create admin (used only if admin does not exist)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@placement.local
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
